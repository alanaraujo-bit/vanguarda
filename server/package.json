{
  "name": "vanguarda-server",
  "description": "Backend do modo online do VANGUARDA: auth, perfis, troféus e relay de partidas em tempo real.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "argon2": "^0.41.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "socket.io": "^4.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}

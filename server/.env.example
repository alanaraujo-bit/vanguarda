# Postgres do Railway (aba "Connect" do plugin Postgres do projeto).
DATABASE_URL=postgresql://user:password@localhost:5432/vanguarda

# Gere um valor aleatório longo (ex.: `openssl rand -hex 32`) — nunca reutilize entre ambientes.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

PORT=8080

# Origem(ns) do frontend estático (GitHub Pages/Vercel) permitidas via CORS.
CORS_ORIGIN=http://localhost:5173
